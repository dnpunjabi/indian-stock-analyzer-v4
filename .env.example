# Google Antigravity SDK & LLM APIs
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API & Multi-Key Rotation Engine
GEMINI_API_KEY_1=your_first_gemini_key
GEMINI_API_KEY_2=your_second_gemini_key
GEMINI_API_KEY_3=your_third_gemini_key
GEMINI_API_KEY_4=your_fourth_gemini_key
GEMINI_HEAVY_MODEL=gemini-1.5-pro
GEMINI_FAST_MODEL=gemini-1.5-flash
GEMINI_ROTATION_STRATEGY=sequential # sequential or round_robin

# Provider-Agnostic LLM Configuration (Options: groq, openai_compat, gemini, together, openrouter, ollama)
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_groq_api_key_here
LLM_HEAVY_MODEL=llama-3.3-70b-versatile
LLM_FAST_MODEL=llama-3.3-70b-versatile
LLM_HEAVY_LABEL=Llama 3.3 70B
LLM_FAST_LABEL=Llama 3.3 70B
LLM_TEMPERATURE=0.2

# WhatsApp Business Cloud API
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
WHATSAPP_RECIPIENT=your_recipient_phone_with_country_code

# Backend Web Server Configuration
PORT=8000
HOST=127.0.0.1

# Angel One SmartAPI (Optional — enables real-time WebSocket streaming)
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_CODE=your_client_code
ANGEL_PASSWORD=your_login_password
ANGEL_TOTP_KEY=your_totp_seed_key

# SerpApi Key (Optional)
SERPAPI_API_KEY=your_serpapi_key_here

# Tavily Search API Key (Optional)
TAVILY_API_KEY=your_tavily_key_here

# Brave Search API Key (Optional - enables RAG with $5 free monthly credit)
BRAVE_API_KEY=your_brave_api_key_here

